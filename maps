private void SelectMarker(Marker marker)
{
    if (_selectedMarker == marker)
    {
        RaiseSelectedMarkerCoordinates(marker);
        return;
    }

    ClearSelection();

    _selectedMarker = marker;
    _selectedMarker.IsSelected = true;

    // Selected styles
    var dotSymbol = new SimpleMarkerSymbol(
        SimpleMarkerSymbolStyle.Circle,
        Color.Yellow,
        12);
    dotSymbol.Outline = new SimpleLineSymbol(SimpleLineSymbolStyle.Solid, Color.Black, 2);

    var circleSymbol = new SimpleLineSymbol(SimpleLineSymbolStyle.Dash, Color.Orange, 3);

    _selectedMarker.DotGraphic.Symbol = dotSymbol;
    _selectedMarker.CircleGraphic.Symbol = circleSymbol;

    RaiseSelectedMarkerCoordinates(_selectedMarker);
}

private void ClearSelection()
{
    if (_selectedMarker == null)
        return;

    _selectedMarker.IsSelected = false;

    var dotSymbol = new SimpleMarkerSymbol(
        SimpleMarkerSymbolStyle.Circle,
        Color.Red,
        10);
    dotSymbol.Outline = new SimpleLineSymbol(SimpleLineSymbolStyle.Solid, Color.White, 1);

    var circleSymbol = new SimpleLineSymbol(SimpleLineSymbolStyle.Solid, Color.DeepSkyBlue, 2);

    _selectedMarker.DotGraphic.Symbol = dotSymbol;
    _selectedMarker.CircleGraphic.Symbol = circleSymbol;

    _selectedMarker = null;
}



private Geometry CreateRadiusCircle(MapPoint centerMapPoint, double radiusMeters)
{
    // Project center to WGS84 for stable geodesic buffering
    var centerWgs84 = (MapPoint)GeometryEngine.Project(centerMapPoint, SpatialReferences.Wgs84);

    // Buffer in meters
    var bufferWgs84 = GeometryEngine.BufferGeodetic(
        centerWgs84,
        radiusMeters,
        LinearUnits.Meters,
        double.NaN,
        GeodeticCurveType.Geodesic);

    // Project back to the map SR
    return GeometryEngine.Project(bufferWgs84, mapView.SpatialReference);
}



private Marker CreateMarker(MapPoint mapPoint, double radiusMeters)
{
    var marker = new Marker
    {
        Id = Guid.NewGuid().ToString("N"),
        Geolocation = mapPoint,
        RadiusMeters = radiusMeters,
        Draggable = true,
        IsSelected = false
    };

    // Center dot
    var dotSymbol = new SimpleMarkerSymbol(
        SimpleMarkerSymbolStyle.Circle,
        Color.Red,
        10);

    dotSymbol.Outline = new SimpleLineSymbol(SimpleLineSymbolStyle.Solid, Color.White, 1);

    var dotGraphic = new Graphic(mapPoint, dotSymbol);

    // Outer radius circle
    var circleGeometry = CreateRadiusCircle(mapPoint, radiusMeters);
    var circleSymbol = new SimpleLineSymbol(SimpleLineSymbolStyle.Solid, Color.DeepSkyBlue, 2);
    var circleGraphic = new Graphic(circleGeometry, circleSymbol);

    // Link graphics back to marker
    dotGraphic.Attributes["MarkerId"] = marker.Id;
    dotGraphic.Attributes["GraphicType"] = "Dot";

    circleGraphic.Attributes["MarkerId"] = marker.Id;
    circleGraphic.Attributes["GraphicType"] = "Circle";

    marker.DotGraphic = dotGraphic;
    marker.CircleGraphic = circleGraphic;

    _markerOverlay.Graphics.Add(circleGraphic);
    _markerOverlay.Graphics.Add(dotGraphic);

    _markers.Add(marker);

    return marker;
}

private async void MapView_MouseLeftButtonUp(object sender, System.Windows.Input.MouseButtonEventArgs e)
{
    try
    {
        var mouseUpPoint = e.GetPosition(mapView);

        if (_isDragging && _dragMarker != null)
        {
            _isDragging = false;
            _mouseDownOnMarker = false;
            _dragMarker = null;

            // restore normal map pan
            mapView.InteractionOptions.IsPanEnabled = true;

            e.Handled = true;
            return;
        }

        Marker hitMarker = await HitTestMarkerAsync(mouseUpPoint);

        if (!_mouseDownOnMarker && hitMarker == null)
        {
            var mapPoint = mapView.ScreenToLocation(mouseUpPoint);
            if (mapPoint != null)
            {
                double radiusMeters = GetRadiusFromDropdown();
                var marker = CreateMarker(mapPoint, radiusMeters);
                marker.ScreenPoint = mouseUpPoint;
                SelectMarker(marker);
            }
        }

        _mouseDownOnMarker = false;
        _isDragging = false;
        _dragMarker = null;
        mapView.InteractionOptions.IsPanEnabled = true;
    }
    catch (Exception ex)
    {
        mapView.InteractionOptions.IsPanEnabled = true;
        System.Diagnostics.Debug.WriteLine(ex);
    }
}


private void MapView_MouseMove(object sender, System.Windows.Input.MouseEventArgs e)
{
    try
    {
        if (!_mouseDownOnMarker || _dragMarker == null)
            return;

        if (e.LeftButton != System.Windows.Input.MouseButtonState.Pressed)
            return;

        var currentScreen = e.GetPosition(mapView);

        double dx = currentScreen.X - _mouseDownScreenPoint.X;
        double dy = currentScreen.Y - _mouseDownScreenPoint.Y;
        double distance = Math.Sqrt(dx * dx + dy * dy);

        if (!_isDragging)
        {
            if (distance < DragStartThresholdPixels)
                return;

            _isDragging = true;

            // VERY IMPORTANT: stop map from panning while marker is dragged
            mapView.InteractionOptions.IsPanEnabled = false;
        }

        var newMapPoint = mapView.ScreenToLocation(currentScreen);
        if (newMapPoint == null)
            return;

        MoveMarker(_dragMarker, newMapPoint, currentScreen);
        RaiseSelectedMarkerCoordinates(_dragMarker);

        e.Handled = true;
    }
    catch (Exception ex)
    {
        System.Diagnostics.Debug.WriteLine(ex);
    }
}




private async void MapView_MouseLeftButtonDown(object sender, System.Windows.Input.MouseButtonEventArgs e)
{
    try
    {
        mapView.Focus();

        _mouseDownScreenPoint = e.GetPosition(mapView);
        _mouseDownOnMarker = false;
        _isDragging = false;
        _dragMarker = null;

        Marker hitMarker = await HitTestMarkerAsync(_mouseDownScreenPoint);

        if (hitMarker != null)
        {
            SelectMarker(hitMarker);

            if (hitMarker.Draggable)
            {
                _dragMarker = hitMarker;
                _mouseDownOnMarker = true;
            }

            e.Handled = true;
        }
        else
        {
            ClearSelection();
        }
    }
    catch (Exception ex)
    {
        System.Diagnostics.Debug.WriteLine(ex);
    }
}





private void RaiseSelectedMarkerCoordinates(Marker marker)
{
    if (marker?.Geolocation == null)
        return;

    var wgs84 = (MapPoint)GeometryEngine.Project(
        marker.Geolocation,
        SpatialReferences.Wgs84);

    SelectedMarkerWgs84Changed?.Invoke(wgs84.X, wgs84.Y);
}





private void MapView_MouseMove(object sender, MouseEventArgs e)
{
    try
    {
        if (_dragMarker == null || e.LeftButton != MouseButtonState.Pressed)
            return;

        var currentScreen = e.GetPosition(mapView);

        double dx = currentScreen.X - _mouseDownScreenPoint.X;
        double dy = currentScreen.Y - _mouseDownScreenPoint.Y;

        if (!_isDragging)
        {
            if (Math.Abs(dx) < DragStartThresholdPixels && Math.Abs(dy) < DragStartThresholdPixels)
                return;

            _isDragging = true;
            _mouseMovedWhileDown = true;

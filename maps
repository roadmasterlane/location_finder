private async Task<Marker> HitTestMarkerAsync(System.Windows.Point screenPoint)
{
    var identifyResult = await mapView.IdentifyGraphicsOverlayAsync(
        _markerOverlay,
        screenPoint,
        HitTolerancePixels,
        false,
        10);

    if (identifyResult?.Graphics == null || identifyResult.Graphics.Count == 0)
        return null;

    // Prefer dot hit over circle hit if both are returned
    var hitGraphic = identifyResult.Graphics
        .OrderBy(g => g.Attributes["GraphicType"]?.ToString() == "Dot" ? 0 : 1)
        .FirstOrDefault();

    if (hitGraphic == null || !hitGraphic.Attributes.ContainsKey("MarkerId"))
        return null;

    var markerId = hitGraphic.Attributes["MarkerId"]?.ToString();
    return _markers.FirstOrDefault(m => m.Id == markerId);
}






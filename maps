private async void MapView_MouseLeftButtonUp(object sender, MouseButtonEventArgs e)
{
    try
    {
        var mouseUpPoint = e.GetPosition(mapView);

        // Case 1: drag finished
        if (_isDragging && _dragMarker != null)
        {
            _isDragging = false;
            _dragMarker = null;
            e.Handled = true;
            return;
        }

        // Case 2: plain click on empty map => create marker
        var hitMarker = await HitTestMarkerAsync(mouseUpPoint);

        if (!_mouseMovedWhileDown && hitMarker == null)
        {
            var mapPoint = mapView.ScreenToLocation(mouseUpPoint);
            if (mapPoint != null)
            {
                double radiusMeters = GetRadiusFromDropdown();
                var marker = CreateMarker(mapPoint, radiusMeters);
                marker.ScreenPoint = mouseUpPoint;

                SelectMarker(marker);
            }
        }

        _dragMarker = null;
        _isDragging = false;
        _mouseMovedWhileDown = false;
    }
    catch (Exception ex)
    {
        // log ex
    }
}




private void MoveMarker(Marker marker, MapPoint newMapPoint, System.Windows.Point newScreenPoint)
{
    marker.Geolocation = newMapPoint;
    marker.ScreenPoint = newScreenPoint;

    marker.DotGraphic.Geometry = newMapPoint;
    marker.CircleGraphic.Geometry = CreateRadiusCircle(newMapPoint, marker.RadiusMeters);
}



private void MapCtrl_KeyDown(object sender, System.Windows.Forms.KeyEventArgs e)
{
    if (e.KeyCode == Keys.Delete && _selectedMarker != null)
    {
        DeleteMarker(_selectedMarker);
        e.Handled = true;
    }
}

private void DeleteMarker(Marker marker)
{
    if (marker == null)
        return;

    _markerOverlay.Graphics.Remove(marker.DotGraphic);
    _markerOverlay.Graphics.Remove(marker.CircleGraphic);
    _markers.Remove(marker);

    if (_selectedMarker == marker)
        _selectedMarker = null;
}



private void RadiusComboBox_SelectedIndexChanged(object sender, EventArgs e)
{
    if (_selectedMarker == null)
        return;

    double radiusMeters = GetRadiusFromDropdown();
    _selectedMarker.RadiusMeters = radiusMeters;
    _selectedMarker.CircleGraphic.Geometry = CreateRadiusCircle(_selectedMarker.Geolocation, radiusMeters);
}

private double GetRadiusFromDropdown()
{
    if (RadiusComboBox?.SelectedItem == null)
        return 50;

    // Example: combo items like "25", "50", "100"
    if (double.TryParse(RadiusComboBox.SelectedItem.ToString(), out double value))
        return value;

    return 50;
}




using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Net.Http;
using System.Threading.Tasks;
using Newtonsoft.Json.Linq;

public static class VectorTileStyleHelper
{
    private static readonly HttpClient _http = new HttpClient();

    /// <summary>
    /// Fetches the default style from a vector tile service, prunes it
    /// down to a lightweight set of layers, and writes it locally.
    /// Returns a file:// URI suitable for ArcGISVectorTiledLayer.
    /// </summary>
    /// <param name="vectorTileServiceUrl">
    /// e.g. "https://yourserver/arcgis/rest/services/YourBasemap/VectorTileServer"
    /// </param>
    /// <param name="layerIdsToKeep">
    /// Style layer IDs (or source-layer names) to retain. Case-insensitive.
    /// </param>
    public static async Task<Uri> BuildLiteStyleAsync(
        string vectorTileServiceUrl,
        HashSet<string> layerIdsToKeep)
    {
        // 1. Resolve the style URL. The standard path is /resources/styles/root.json
        //    but we confirm via the service metadata in case it's customized.
        var serviceMetaUrl = $"{vectorTileServiceUrl.TrimEnd('/')}?f=json";
        var serviceJson = await _http.GetStringAsync(serviceMetaUrl);
        var serviceMeta = JObject.Parse(serviceJson);

        var defaultStyles = serviceMeta["defaultStyles"]?.ToString() ?? "resources/styles";
        var styleUrl = $"{vectorTileServiceUrl.TrimEnd('/')}/{defaultStyles.TrimStart('/')}/root.json";

        // 2. Fetch the full style JSON
        var styleJson = await _http.GetStringAsync(styleUrl);
        var style = JObject.Parse(styleJson);

        // 3. Filter the layers array
        var allLayers = (JArray)style["layers"];
        if (allLayers == null)
            throw new InvalidOperationException("Style has no layers array.");

        // Match against layer "id" or "source-layer" (case-insensitive)
        var keep = new HashSet<string>(layerIdsToKeep, StringComparer.OrdinalIgnoreCase);

        var filtered = new JArray(
            allLayers.Where(l =>
            {
                var id = l["id"]?.ToString();
                var sourceLayer = l["source-layer"]?.ToString();
                return (id != null && keep.Contains(id)) ||
                       (sourceLayer != null && keep.Contains(sourceLayer));
            }));

        System.Diagnostics.Debug.WriteLine(
            $"Vector tile style pruned: {allLayers.Count} -> {filtered.Count} layers");

        style["layers"] = filtered;

        // 4. Write to a stable location next to the executable so the
        //    Runtime can resolve it as a file:// URI.
        var outputPath = Path.Combine(
            AppDomain.CurrentDomain.BaseDirectory, "lite-style.json");

        File.WriteAllText(outputPath, style.ToString());

        return new Uri(outputPath);
    }
}





private async Task<Uri> BuildLiteStyleAsync(string serviceUrl)
{
    using var http = new HttpClient();
    var styleJson = await http.GetStringAsync($"{serviceUrl}/resources/styles/root.json");
    
    var style = Newtonsoft.Json.Linq.JObject.Parse(styleJson);
    var layers = (Newtonsoft.Json.Linq.JArray)style["layers"];
    
    // Keep only the layer types/IDs you actually need
    var keep = new HashSet<string> { "land", "water", "roads-major", "boundaries", "labels-major" };
    
    var filtered = new Newtonsoft.Json.Linq.JArray(
        layers.Where(l => keep.Contains(l["id"]?.ToString()) 
                       || keep.Contains(l["source-layer"]?.ToString())));
    
    style["layers"] = filtered;
    
    var tempPath = Path.Combine(Path.GetTempPath(), "lite-style.json");
    File.WriteAllText(tempPath, style.ToString());
    return new Uri(tempPath);
}





private void InitializeMarkerOverlays()
{
    _markerDotOverlay = new GraphicsOverlay();
    _markerCircleOverlay = new GraphicsOverlay();

    var dotSymbol = new SimpleMarkerSymbol(SimpleMarkerSymbolStyle.Circle, Color.Red, 10);
    dotSymbol.Outline = new SimpleLineSymbol(SimpleLineSymbolStyle.Solid, Color.White, 1);

    var circleSymbol = new SimpleLineSymbol(SimpleLineSymbolStyle.Solid, Color.DeepSkyBlue, 2);

    _markerDotOverlay.Renderer = new SimpleRenderer(dotSymbol);
    _markerCircleOverlay.Renderer = new SimpleRenderer(circleSymbol);

    mapView.GraphicsOverlays.Add(_markerCircleOverlay);
    mapView.GraphicsOverlays.Add(_markerDotOverlay);
}




private Marker CreateMarker(MapPoint mapPoint, double radiusMeters)
{
    var marker = new Marker
    {
        Id = Guid.NewGuid().ToString("N"),
        Geolocation = mapPoint,
        RadiusMeters = radiusMeters,
        Draggable = true,
        IsSelected = false
    };

    var dotGraphic = new Graphic(mapPoint);
    dotGraphic.Attributes["MarkerId"] = marker.Id;
    dotGraphic.Attributes["GraphicType"] = "Dot";

    var circleGraphic = new Graphic(CreateRadiusCircle(mapPoint, radiusMeters));
    circleGraphic.Attributes["MarkerId"] = marker.Id;
    circleGraphic.Attributes["GraphicType"] = "Circle";

    marker.DotGraphic = dotGraphic;
    marker.CircleGraphic = circleGraphic;

    _markerDotOverlay.Graphics.Add(dotGraphic);
    _markerCircleOverlay.Graphics.Add(circleGraphic);

    _markers.Add(marker);

    return marker;
}




private readonly Queue<Marker> _markerPool = new Queue<Marker>();

private Marker GetOrCreateMarker(MapPoint mapPoint, double radiusMeters)
{
    if (_markerPool.Count > 0)
    {
        var marker = _markerPool.Dequeue();
        UpdateMarkerGeometry(marker, mapPoint, radiusMeters);
        marker.IsSelected = false;
        marker.DotGraphic.Symbol = null;
        return marker;
    }

    return CreateMarker(mapPoint, radiusMeters);
}

private void ReleaseMarker(Marker marker)
{
    _markerDotOverlay.Graphics.Remove(marker.DotGraphic);
    _markerCircleOverlay.Graphics.Remove(marker.CircleGraphic);
    _markers.Remove(marker);

    _markerPool.Enqueue(marker);
}




private void SetMarkerSelected(Marker marker, bool isSelected)
{
    marker.IsSelected = isSelected;

    if (isSelected)
    {
        marker.DotGraphic.Symbol = _selectedDotSymbol;
    }
    else
    {
        marker.DotGraphic.Symbol = null; // fall back to overlay renderer
    }
}




private void UpdateMarkerGeometry(Marker marker, MapPoint newPoint, double radiusMeters)
{
    marker.Geolocation = newPoint;
    marker.RadiusMeters = radiusMeters;

    marker.DotGraphic.Geometry = newPoint;
    marker.CircleGraphic.Geometry = CreateRadiusCircle(newPoint, radiusMeters);
}



private Marker CreateMarker(MapPoint mapPoint, double radiusMeters)
{
    var marker = new Marker
    {
        Id = Guid.NewGuid().ToString("N"),
        Geolocation = mapPoint,
        RadiusMeters = radiusMeters,
        Draggable = true,
        IsSelected = false
    };

    var dotGraphic = new Graphic(mapPoint);
    dotGraphic.Attributes["MarkerId"] = marker.Id;
    dotGraphic.Attributes["GraphicType"] = "Dot";

    var circleGeometry = CreateRadiusCircle(mapPoint, radiusMeters);
    var circleGraphic = new Graphic(circleGeometry);
    circleGraphic.Attributes["MarkerId"] = marker.Id;
    circleGraphic.Attributes["GraphicType"] = "Circle";

    marker.DotGraphic = dotGraphic;
    marker.CircleGraphic = circleGraphic;

    _markerCircleOverlay.Graphics.Add(circleGraphic);
    _markerDotOverlay.Graphics.Add(dotGraphic);

    _markers.Add(marker);

    return marker;
}





public class Marker
{
    public string Id { get; set; }
    public MapPoint Geolocation { get; set; }
    public double RadiusMeters { get; set; }
    public bool Draggable { get; set; }
    public bool IsSelected { get; set; }

    public Graphic DotGraphic { get; set; }
    public Graphic CircleGraphic { get; set; }
}





